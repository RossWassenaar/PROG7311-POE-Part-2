@model GLMS.Web.Models.Contract
@{ ViewData["Title"] = "Delete Contract"; }

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</div>
            <div class="card-body">
                <p>Delete contract <strong>#@Model.Id</strong> for <strong>@Model.Client?.Name</strong>?</p>
                <dl class="row small">
                    <dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Status</dd>
                    <dt class="col-sm-4">Level</dt><dd class="col-sm-8">@Model.ServiceLevel</dd>
                </dl>
                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
