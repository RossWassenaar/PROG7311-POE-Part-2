@model GLMS.Web.Models.Contract
@{ ViewData["Title"] = "Contract Dossier"; }

<div class="row">
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-shield-check text-success me-2"></i>Contract #@Model.Id</span>
                <span class="badge badge-@Model.Status.ToLower().Replace(" ","")">@Model.Status</span>
            </div>
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="text-muted small text-uppercase fw-bold mb-1" style="letter-spacing:1px;">Client Entity</div>
                    <div class="fs-5 fw-bold text-white"><i class="bi bi-building text-info me-2"></i>@Model.Client?.Name</div>
                </div>
                
                <div class="mb-4">
                    <div class="text-muted small text-uppercase fw-bold mb-1" style="letter-spacing:1px;">Service Level</div>
                    <div class="fs-6 text-white"><i class="bi bi-star-fill text-warning me-2"></i>@Model.ServiceLevel SLA</div>
                </div>
                
                <div class="p-3 rounded mb-4 border border-secondary" style="background: rgba(0,0,0,0.2);">
                    <div class="row text-center">
                        <div class="col-6 border-end border-secondary">
                            <div class="text-muted small mb-1">Commencement</div>
                            <div class="font-monospace text-white small">@Model.StartDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small mb-1">Termination</div>
                            <div class="font-monospace text-white small">@Model.EndDate.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                </div>
                
                <div class="mb-4">
                    <div class="text-muted small text-uppercase fw-bold mb-2" style="letter-spacing:1px;">Legal Agreement</div>
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <a asp-action="DownloadAgreement" asp-route-id="@Model.Id" class="btn btn-outline-success w-100 d-flex justify-content-center align-items-center gap-2">
                            <i class="bi bi-file-pdf-fill fs-5"></i> Download PDF Document
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-dark border-secondary text-center small mb-0 py-2 text-muted">
                            <i class="bi bi-exclamation-circle me-1"></i> No document uploaded
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 p-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary flex-grow-1"><i class="bi bi-pencil me-2"></i>Edit Contract</a>
                <a asp-action="Index" class="btn btn-dark border-secondary"><i class="bi bi-arrow-left"></i></a>
            </div>
        </div>
    </div>
    
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-lightning-charge text-warning me-2"></i>Logged Service Requests (@Model.ServiceRequests.Count)</span>
                <a asp-controller="ServiceRequest" asp-action="Create" asp-route-contractId="@Model.Id" class="btn btn-sm btn-outline-warning text-white"><i class="bi bi-plus"></i> New Request</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">Description</th>
                                <th class="text-end">USD</th>
                                <th class="text-end">ZAR</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.ServiceRequests.Any())
                            {
                                <tr><td colspan="4" class="text-center py-5 text-muted">No service requests logged yet.</td></tr>
                            }
                            @foreach (var r in Model.ServiceRequests)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="text-white text-truncate" style="max-width: 250px;">@r.Description</div>
                                    </td>
                                    <td class="text-end font-monospace text-muted">$@r.CostUSD.ToString("N2")</td>
                                    <td class="text-end font-monospace fw-bold text-success">R @r.CostZAR.ToString("N2")</td>
                                    <td class="text-center"><span class="badge badge-@r.Status.ToLower()">@r.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
