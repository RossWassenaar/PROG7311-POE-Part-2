@model GLMS.Web.Models.Contract
@{ ViewData["Title"] = "Update Contract"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0" style="background: rgba(15, 23, 42, 0.6); box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
            <div class="card-header border-bottom border-secondary p-4 d-flex align-items-center">
                <i class="bi bi-pencil text-primary fs-4 me-3"></i>
                <h5 class="mb-0 text-white fw-bold">Update Contract #@Model.Id</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    
                    <div class="mb-4">
                        <label asp-for="ClientId" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;">Target Client</label>
                        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select form-select-lg bg-dark border-secondary text-white"></select>
                        <span asp-validation-for="ClientId" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="row mb-4 g-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                            <input asp-for="StartDate" type="date" class="form-control bg-dark border-secondary text-white font-monospace" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                            <input asp-for="EndDate" type="date" class="form-control bg-dark border-secondary text-white font-monospace" />
                        </div>
                    </div>
                    
                    <div class="row mb-4 g-3">
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                            <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select bg-dark border-secondary text-white"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ServiceLevel" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                            <select asp-for="ServiceLevel" asp-items="ViewBag.ServiceLevels" class="form-select bg-dark border-secondary text-white"></select>
                        </div>
                    </div>
                    
                    <div class="mb-4 p-4 rounded bg-dark bg-opacity-50 border border-secondary">
                        <label class="form-label text-white fw-medium d-block mb-3"><i class="bi bi-file-pdf text-danger me-2"></i>Update Agreement File</label>
                        @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                        {
                            <div class="alert alert-dark border border-secondary py-2 mb-3 d-flex align-items-center">
                                <i class="bi bi-file-earmark-check text-success fs-5 me-2"></i>
                                <div>
                                    <div class="small text-muted mb-0">Current Document</div>
                                    <div class="text-white fw-medium">@Model.SignedAgreementFileName</div>
                                </div>
                            </div>
                        }
                        <input type="file" name="signedAgreement" accept=".pdf" class="form-control bg-dark border-secondary text-muted" />
                        <div class="text-muted small mt-2"><i class="bi bi-info-circle text-info me-1"></i>Leave blank to retain current document.</div>
                    </div>
                    
                    <div class="d-flex gap-3 justify-content-end pt-3 border-top border-secondary">
                        <a asp-action="Index" class="btn btn-dark border-secondary text-light px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
