@model GLMS.Web.Models.ServiceRequest
@{ ViewData["Title"] = "Request Telemetry"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0" style="background: linear-gradient(180deg, rgba(15, 23, 42, 1) 0%, rgba(15, 23, 42, 0.4) 100%); box-shadow: 0 10px 30px rgba(0,0,0,0.4);">
            <div class="card-header border-bottom border-secondary d-flex justify-content-between align-items-center p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-dark border border-secondary d-flex justify-content-center align-items-center" style="width:48px;height:48px;">
                        <i class="bi bi-inbox text-warning fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 text-white fw-bold">Request #@Model.Id</h4>
                        <div class="text-muted small">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm:ss")</div>
                    </div>
                </div>
                <span class="badge badge-@Model.Status.ToLower() fs-6 px-3 py-2">@Model.Status</span>
            </div>
            
            <div class="card-body p-0">
                <div class="p-4 border-bottom border-secondary">
                    <div class="text-uppercase small fw-bold text-muted mb-2" style="letter-spacing: 1px;">Task Description</div>
                    <p class="text-white fs-5 mb-0" style="line-height: 1.6;">@Model.Description</p>
                </div>
                
                <div class="row g-0 border-bottom border-secondary">
                    <div class="col-sm-6 p-4 border-end border-secondary">
                        <div class="text-uppercase small fw-bold text-muted mb-2" style="letter-spacing: 1px;">Client Entity</div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-building text-info fs-5"></i>
                            <span class="text-white fw-medium fs-5">@Model.Contract?.Client?.Name</span>
                        </div>
                    </div>
                    <div class="col-sm-6 p-4">
                        <div class="text-uppercase small fw-bold text-muted mb-2" style="letter-spacing: 1px;">Contract Link</div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-text text-purple fs-5"></i>
                            <a asp-controller="Contract" asp-action="Details" asp-route-id="@Model.ContractId" class="text-decoration-none fw-medium fs-5 text-white hover-primary">
                                #@Model.ContractId
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="p-4 bg-dark bg-opacity-50">
                    <div class="text-uppercase small fw-bold text-muted mb-3" style="letter-spacing: 1px;">Financial Telemetry</div>
                    
                    <div class="d-flex justify-content-between align-items-center bg-dark border border-secondary rounded p-3 mb-3">
                        <div class="text-muted">Base Cost (USD)</div>
                        <div class="font-monospace fs-5 text-white">$@Model.CostUSD.ToString("N2")</div>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center px-3 mb-3 text-muted small font-monospace">
                        <div><i class="bi bi-arrow-down-up me-2"></i>Exchange Rate Captured</div>
                        <div>@Model.ExchangeRate</div>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center bg-dark border border-success border-opacity-50 rounded p-3" style="background: linear-gradient(90deg, rgba(16, 185, 129, 0.05) 0%, rgba(16, 185, 129, 0.15) 100%) !important;">
                        <div class="text-success fw-medium">Final Cost (ZAR)</div>
                        <div class="font-monospace fs-3 fw-bold" style="color: var(--neon-green);">R @Model.CostZAR.ToString("N2")</div>
                    </div>
                </div>
            </div>
            
            <div class="card-footer border-top border-secondary bg-transparent p-4 d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-dark border-secondary px-4"><i class="bi bi-arrow-left me-2"></i>Return</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4"><i class="bi bi-trash me-2"></i>Delete Record</a>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-primary:hover { color: var(--neon-blue) !important; text-decoration: underline !important; }
</style>
