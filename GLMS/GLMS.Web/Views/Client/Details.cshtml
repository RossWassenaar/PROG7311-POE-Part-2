@model GLMS.Web.Models.Client
@{ ViewData["Title"] = "Client Intel"; }

<div class="row">
    <div class="col-lg-4">
        <div class="card mb-4 border-0" style="background: linear-gradient(135deg, rgba(15, 23, 42, 0.8), rgba(30, 27, 75, 0.8));">
            <div class="card-body p-4 text-center">
                <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 80px; height: 80px; background: rgba(56, 189, 248, 0.1); border: 2px solid var(--neon-blue);">
                    <i class="bi bi-building fs-1" style="color: var(--neon-blue);"></i>
                </div>
                <h4 class="text-white fw-bold mb-1">@Model.Name</h4>
                <p class="text-muted small mb-3">Client #@Model.Id</p>
                <div class="badge bg-dark border border-secondary text-light px-3 py-2 mb-4">
                    <i class="bi bi-geo-alt-fill text-danger me-1"></i> @Model.Region
                </div>
                
                <div class="d-flex flex-column gap-2 text-start p-3 rounded" style="background: rgba(0,0,0,0.2);">
                    <div class="small text-muted text-uppercase fw-bold" style="letter-spacing:1px;">Contact Comms</div>
                    <div class="text-white"><i class="bi bi-headset text-info me-2"></i>@Model.ContactDetails</div>
                </div>
                
                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary flex-grow-1"><i class="bi bi-pencil me-2"></i>Update Intel</a>
                    <a asp-action="Index" class="btn btn-dark border-secondary"><i class="bi bi-arrow-left"></i></a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-richtext text-purple me-2"></i>Active Contracts (@Model.Contracts.Count)</span>
                <a asp-controller="Contract" asp-action="Create" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> New Contract</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Level</th>
                                <th>Status</th>
                                <th>Timeline</th>
                                <th class="pe-4 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Contracts.Any())
                            {
                                <tr><td colspan="4" class="text-center py-5 text-muted">No contracts bound to this client.</td></tr>
                            }
                            @foreach (var c in Model.Contracts)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium text-white">@c.ServiceLevel</td>
                                    <td><span class="badge badge-@c.Status.ToLower().Replace(" ","")">@c.Status</span></td>
                                    <td class="small text-muted font-monospace">
                                        @c.StartDate.ToString("MM/dd/yy") <i class="bi bi-arrow-right-short text-info"></i> @c.EndDate.ToString("MM/dd/yy")
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a asp-controller="Contract" asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-dark border-secondary text-info">View Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
