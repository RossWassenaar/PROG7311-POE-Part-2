@model GLMS.Web.Models.Client
@{ ViewData["Title"] = "Edit Client Profile"; }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0" style="background: rgba(15, 23, 42, 0.6); box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
            <div class="card-header border-bottom border-secondary p-4 d-flex align-items-center">
                <i class="bi bi-pencil text-primary fs-4 me-3"></i>
                <h5 class="mb-0 text-white fw-bold">Update Client Intel</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" style="display:none"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary"><i class="bi bi-building text-info"></i></span>
                            <input asp-for="Name" class="form-control form-control-lg bg-dark border-secondary text-white" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="ContactDetails" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary"><i class="bi bi-headset text-info"></i></span>
                            <input asp-for="ContactDetails" class="form-control bg-dark border-secondary text-white" />
                        </div>
                        <span asp-validation-for="ContactDetails" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Region" class="form-label text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary"><i class="bi bi-geo-alt text-info"></i></span>
                            <input asp-for="Region" class="form-control bg-dark border-secondary text-white" />
                        </div>
                        <span asp-validation-for="Region" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="d-flex gap-3 pt-3 border-top border-secondary mt-2">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i>Save Changes</button>
                        <a asp-action="Index" class="btn btn-dark border-secondary text-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
