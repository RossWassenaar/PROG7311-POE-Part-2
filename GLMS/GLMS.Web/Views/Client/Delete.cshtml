@model GLMS.Web.Models.Client
@{ ViewData["Title"] = "Delete Client"; }

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</div>
            <div class="card-body">
                <p>Are you sure you want to delete client <strong>@Model.Name</strong>?</p>
                @if (Model.Contracts.Any())
                {
                    <div class="alert alert-warning small"><i class="bi bi-exclamation-circle me-1"></i>This client has @Model.Contracts.Count contract(s). Deleting may affect related records.</div>
                }
                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
