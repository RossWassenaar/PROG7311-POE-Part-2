<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GLMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-base: #050505;
            --bg-surface: #0a0a0a;
            --bg-surface-alt: #111111;
            --border-color: #333333;
            --border-highlight: #444444;
            --neon-cyan: #00f0ff;
            --neon-orange: #ff5e00;
            --neon-green: #00ff66;
            --neon-red: #ff003c;
            --text-main: #cccccc;
            --text-muted: #666666;
            --sidebar-width: 220px;
        }


        * {
            border-radius: 0px !important;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-base);
            color: var(--text-main);
            margin: 0;
            background-image: 
                linear-gradient(var(--border-color) 1px, transparent 1px),
                linear-gradient(90deg, var(--border-color) 1px, transparent 1px);
            background-size: 100px 100px;
            background-position: -1px -1px;
            min-height: 100vh;
        }

        h1, h2, h3, h4, h5, h6, .brand-text, .font-monospace {
            font-family: 'JetBrains Mono', monospace !important;
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }


        .sidebar {
            width: var(--sidebar-width);
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            background: var(--bg-surface);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 1.25rem;
            font-weight: 800;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--bg-surface-alt);
        }

        .sidebar-brand i { color: var(--neon-cyan); }

        .sidebar-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--neon-orange);
            padding: 1.5rem 1.5rem 0.5rem;
            border-top: 1px solid var(--border-color);
            margin-top: 1rem;
        }

        .sidebar-nav { list-style: none; padding: 0; margin: 0; }
        
        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.5rem;
            color: var(--text-main);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
            border-left: 2px solid transparent;
            transition: all 0s;
        }

        .sidebar-nav a:hover {
            color: #fff;
            background: var(--bg-surface-alt);
            border-left: 2px solid var(--border-highlight);
        }

        .sidebar-nav a.active {
            color: var(--neon-cyan);
            background: rgba(0, 240, 255, 0.05);
            border-left: 2px solid var(--neon-cyan);
        }


        .main-content {
            margin-left: var(--sidebar-width);
            padding: 2rem;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }


        .topbar {
            background: var(--bg-surface);
            border: 1px solid var(--border-color);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .topbar h1 {
            font-size: 1.2rem;
            color: #fff;
            margin: 0;
        }

        .card {
            background: var(--bg-surface);
            border: 1px solid var(--border-color);
            box-shadow: 4px 4px 0px rgba(0,0,0,1); 
        }

        .card-header {
            background: var(--bg-surface-alt);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 1.5rem;
            font-family: 'JetBrains Mono', monospace;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            color: #fff;
        }


        .table {
            color: var(--text-main);
            margin-bottom: 0;
            --bs-table-bg: transparent;
            --bs-table-hover-bg: var(--bg-surface-alt);
        }
        
        .table th {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            border-top: 0;
            padding: 1rem;
        }

        .table td {
            border-bottom: 1px solid var(--border-color);
            padding: 1rem;
            vertical-align: middle;
        }


        .badge {
            font-family: 'JetBrains Mono', monospace;
            padding: 0.3em 0.6em;
            font-weight: 700;
            border: 1px solid;
            background: transparent;
        }
        .badge-draft { color: var(--text-muted); border-color: var(--text-muted); }
        .badge-active { color: var(--neon-cyan); border-color: var(--neon-cyan); background: rgba(0,240,255,0.1); }
        .badge-expired { color: var(--neon-red); border-color: var(--neon-red); background: rgba(255,0,60,0.1); }
        .badge-onhold { color: var(--neon-orange); border-color: var(--neon-orange); background: rgba(255,94,0,0.1); }
        .badge-pending { color: var(--neon-orange); border-color: var(--neon-orange); background: rgba(255,94,0,0.1); }
        .badge-processing { color: #b000ff; border-color: #b000ff; background: rgba(176,0,255,0.1); }
        .badge-completed { color: var(--neon-green); border-color: var(--neon-green); background: rgba(0,255,102,0.1); }
        .badge-cancelled { color: var(--neon-red); border-color: var(--neon-red); background: rgba(255,0,60,0.1); }


        .btn { 
            font-family: 'JetBrains Mono', monospace; 
            font-weight: 700; 
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            border: 1px solid;
            transition: none;
        }
        .btn-primary { 
            background: transparent; 
            color: var(--neon-cyan);
            border-color: var(--neon-cyan);
        }
        .btn-primary:hover {
            background: var(--neon-cyan);
            color: #000;
        }
        .btn-outline-primary {
            color: var(--neon-cyan); border-color: var(--neon-cyan);
        }
        .btn-outline-primary:hover {
            background: var(--neon-cyan); color: #000;
        }
        
        .form-control, .form-select, .input-group-text {
            background-color: var(--bg-base);
            border: 1px solid var(--border-color);
            color: #fff;
            font-family: 'JetBrains Mono', monospace;
        }
        .form-control:focus, .form-select:focus {
            background-color: var(--bg-surface-alt);
            border-color: var(--neon-cyan);
            box-shadow: none;
            color: #fff;
        }
        .input-group-text {
            color: var(--neon-orange);
            font-weight: bold;
        }
        
        .form-label { font-family: 'JetBrains Mono', monospace; font-weight: 700; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; }
        

        .alert { border: 1px solid; background: var(--bg-surface); }
        .alert-success { border-color: var(--neon-green); color: var(--neon-green); border-left: 4px solid var(--neon-green); }
        .alert-danger { border-color: var(--neon-red); color: var(--neon-red); border-left: 4px solid var(--neon-red); }


        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); border-left: 1px solid var(--border-color); }
        ::-webkit-scrollbar-thumb { background: var(--border-highlight); }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-brand">
        <span class="brand-text">GLMS</span>
    </div>
    
    <div class="sidebar-label">OVERVIEW</div>
    <ul class="sidebar-nav">
        <li>
            <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                DASHBOARD
            </a>
        </li>
    </ul>
    
    <div class="sidebar-label">MANAGEMENT</div>
    <ul class="sidebar-nav">
        <li>
            <a asp-controller="Client" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Client" ? "active" : "")">
                CLIENTS
            </a>
        </li>
        <li>
            <a asp-controller="Contract" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Contract" ? "active" : "")">
                CONTRACTS
            </a>
        </li>
        <li>
            <a asp-controller="ServiceRequest" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequest" ? "active" : "")">
                SERVICE REQUESTS
            </a>
        </li>
    </ul>
</div>

<div class="main-content">
    <div class="topbar">
        <h1>@(ViewData["Title"] ?? "DASHBOARD")</h1>
        <div class="d-flex align-items-center gap-3 font-monospace small">
            <span class="text-white">TECHMOVE LOGISTICS: <span style="color:var(--neon-green)">ONLINE</span></span>
        </div>
    </div>
    
    <div class="container-fluid px-0 flex-grow-1">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4 d-flex align-items-center" role="alert">
                <div class="font-monospace">SYS.SUCCESS: @TempData["Success"]</div>
                <button type="button" class="btn-close btn-close-white rounded-0" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4 d-flex align-items-center" role="alert">
                <div class="font-monospace">SYS.ERR: @TempData["Error"]</div>
                <button type="button" class="btn-close btn-close-white rounded-0" data-bs-dismiss="alert"></button>
            </div>
        }
        
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
